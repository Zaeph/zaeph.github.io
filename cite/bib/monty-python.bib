}

@article{proulx2010,
  ids = {proulx2010a},
  title = {When {{Is}} the {{Unfamiliar}} the {{Uncanny}}? {{Meaning Affirmation After Exposure}} to {{Absurdist Literature}}, {{Humor}}, and {{Art}}},
