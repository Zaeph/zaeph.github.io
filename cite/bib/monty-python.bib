  pages = {63--83},
  issn = {0171-5410},
  url = {https://www.jstor.org/stable/43023313},
  urldate = {2020-02-07},
  abstract = {The phenomenon of comedy and humour is a pervasive and yet ill understood force in contemporary British society. The first part of this study considers the historical development of the various institutions and media which have served and still serve to articulate comedy. The contribution of the music halls is discussed; but the major emphasis is on the role played by the twentieth century media, starting with radio and followed by films and, in particular, television. The effects of the various media on the genres of comedy are indicated, showing how music hall comedians gave way to comic actors and how situation comedy and related comedy programmes have developed on television. The role played by the BBC in the past forty years is brought out. The second part of the study attempts to assess the social and political ramifications of comedy and humour in British society. The social role of the comedian is analyzed. Further sections examine the class and regional aspects of comedy and humour.},
  file = {/home/zaeph/Calibre/Richard Alexander/British Comedy and Humour_ Social and Cultural Background (2443)/British Comedy and Humour_ Social and Cult - Richard Alexander.pdf},
  keywords = {comedy,context},
  library = {virtual},
  number = {1}
}

