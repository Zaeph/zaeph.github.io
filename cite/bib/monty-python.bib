  urldate = {2020-02-10},
  abstract = {Monty Python, the genius comedy troupe from Britain, single-handedly revolutionized sketch comedy and paved the way for everything from Saturday Night Live to Austin Powers . Now, in their official oral history, founding members John Cleese, Eric Idle, Terry Gilliam, Terry Jones, and Michael Palin take readers behind the scenes in this no-holds-barred look at their lives and unforgettable comic works like "The Spanish Inquisition," "Dead Parrot," Monty Python's Life of Brian , Monty Python and the Holy Grail (inspiration for the hit Broadway musical Spamalot ), and many, many more, with never-before-seen photos and rare interviews from friends and collaborators.},
